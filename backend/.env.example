PORT=8000
MONGODB_URI=mongodb://localhost:27017/ai-translate
REDIS_URL=redis://localhost:6379
JWT_SECRET=your-secret-here
SESSION_TTL=604800
USER_CACHE_TTL=3600
TRANSLATION_CACHE_TTL=600

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_PATH=/oauth/google/callback

# Microsoft (Hotmail) OAuth
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_REDIRECT_PATH=/oauth/hotmail/callback

# Frontend
FRONTEND_URL=http://localhost:3000

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# AI API Keys
GEMINI_API_KEY=your-gemini-api-key
KIMI_API_KEY=your-kimi-api-key

# AI Model Config (optional, defaults shown)
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0
KIMI_MODEL=moonshot-v1-8k
KIMI_API_URL=https://api.moonshot.cn/v1/chat/completions
KIMI_TEMPERATURE=0.3
AUDIO_MIME_TYPE=audio/ogg
