# Backend API
NEXT_PUBLIC_API_URL=http://localhost:60000

# Google OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:60000/oauth/google/callback
NEXT_PUBLIC_GOOGLE_OAUTH_URL=https://accounts.google.com/o/oauth2/v2/auth?client_id={NEXT_PUBLIC_GOOGLE_CLIENT_ID}&redirect_uri={NEXT_PUBLIC_GOOGLE_REDIRECT_URI}&response_type=code&scope=openid%20email%20profile&access_type=offline&prompt=select_account
